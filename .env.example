# Copia este archivo a ".env" (o ".env.local") y completa los valores reales.
# El archivo ".env" nunca se sube a GitHub (está en .gitignore).
# Estas variables son solo para las integraciones opcionales de Gmail y
# OneDrive — la app funciona sin ellas, esas dos funciones simplemente no
# van a estar disponibles hasta que se completen.

VITE_MS_CLIENT_ID=
VITE_MS_TENANT_ID=
VITE_ONEDRIVE_FOLDER=CAUSAS JOA
VITE_GMAIL_CLIENT_ID=
VITE_SUPABASE_ANON_KEY=
